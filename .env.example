OPENAI_API_KEY=

# SonarQube (optional — omit for standalone AI review mode)
IRA_SONAR_URL=
IRA_SONAR_TOKEN=
IRA_PROJECT_KEY=

# SCM Provider: bitbucket (default) or github
IRA_SCM_PROVIDER=bitbucket

# Bitbucket
IRA_BITBUCKET_TOKEN=
IRA_BITBUCKET_URL=
IRA_REPO=

# GitHub (alternative to Bitbucket)
IRA_GITHUB_TOKEN=
IRA_GITHUB_REPO=
IRA_GITHUB_URL=

# Optional: JIRA integration
IRA_JIRA_URL=
IRA_JIRA_EMAIL=
IRA_JIRA_TOKEN=

# Optional: Notifications
IRA_SLACK_WEBHOOK=
IRA_TEAMS_WEBHOOK=
