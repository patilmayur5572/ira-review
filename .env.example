# AI API key (also accepts OPENAI_API_KEY as fallback)
IRA_AI_API_KEY=

# AI provider config (optional — defaults to openai / gpt-4o-mini)
# IRA_AI_BASE_URL=
# IRA_AI_API_VERSION=
# IRA_AI_DEPLOYMENT_NAME=

# SonarQube (optional — omit for standalone AI review mode)
IRA_SONAR_URL=
IRA_SONAR_TOKEN=
IRA_PROJECT_KEY=

# SCM Provider: bitbucket (default) or github
IRA_SCM_PROVIDER=bitbucket

# Bitbucket
IRA_BITBUCKET_TOKEN=
IRA_BITBUCKET_URL=
IRA_REPO=

# GitHub (alternative to Bitbucket)
IRA_GITHUB_TOKEN=
IRA_GITHUB_REPO=
IRA_GITHUB_URL=

# Minimum severity filter (default: CRITICAL)
# IRA_MIN_SEVERITY=CRITICAL

# Optional: JIRA integration
IRA_JIRA_URL=
IRA_JIRA_EMAIL=
IRA_JIRA_TOKEN=
# IRA_JIRA_TICKET=

# Optional: Notifications
IRA_SLACK_WEBHOOK=
IRA_TEAMS_WEBHOOK=
