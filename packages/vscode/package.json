{
  "name": "ira-review-vscode",
  "displayName": "IRA — AI Code Reviews",
  "description": "AI-powered code reviews inside your editor. Privacy-first, local-only.",
  "version": "2.0.1",
  "publisher": "ira-review",
  "license": "SEE LICENSE IN LICENSE",
  "icon": "resources/ira-icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/patilmayur5572/ira-review.git",
    "directory": "packages/vscode"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Testing",
    "Other"
  ],
  "keywords": [
    "code review",
    "AI",
    "SonarQube",
    "pull request",
    "security",
    "JIRA",
    "CodeRabbit alternative"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "build": "node esbuild.js",
    "build:prod": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "package": "vsce package",
    "publish-ext": "vsce publish && ovsx publish",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "ira-review": "file:../../"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0"
  },
  "contributes": {
    "commands": [
      {
        "command": "ira.reviewPR",
        "title": "IRA: Review Current PR"
      },
      {
        "command": "ira.reviewFile",
        "title": "IRA: Review Current File"
      },
      {
        "command": "ira.generateTests",
        "title": "IRA: Generate Tests"
      },

      {
        "command": "ira.configure",
        "title": "IRA: Configure"
      },
      {
        "command": "ira.applyFix",
        "title": "IRA: Apply Fix"
      },
      {
        "command": "ira.dismissIssue",
        "title": "IRA: Dismiss Issue"
      },
      {
        "command": "ira.showIssueDetail",
        "title": "IRA: Show Issue Detail"
      },
      {
        "command": "ira.generatePRDescription",
        "title": "IRA: Generate PR Description"
      },
      {
        "command": "ira.signIn",
        "title": "IRA: Sign In (GitHub / Bitbucket)"
      },
      {
        "command": "ira.signOut",
        "title": "IRA: Sign Out"
      },
      {
        "command": "ira.initRules",
        "title": "IRA: Init Rules File"
      },
      {
        "command": "ira.validateJiraAC",
        "title": "IRA: Validate JIRA AC"
      },
      {
        "command": "ira.suggestAC",
        "title": "IRA: Suggest Acceptance Criteria"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "ira.applyFix",
          "when": "false"
        },
        {
          "command": "ira.showIssueDetail",
          "when": "false"
        },
        {
          "command": "ira.dismissIssue",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "IRA Review",
      "properties": {
        "ira.scmProvider": {
          "type": "string",
          "enum": [
            "github",
            "bitbucket"
          ],
          "default": "github",
          "description": "Source control provider"
        },
        "ira.aiProvider": {
          "type": "string",
          "enum": [
            "copilot",
            "openai",
            "azure-openai",
            "anthropic",
            "ollama"
          ],
          "default": "copilot",
          "description": "AI provider for code reviews (copilot = use your existing GitHub Copilot, no API key needed)"
        },
        "ira.aiModel": {
          "type": "string",
          "default": "gpt-4o-mini",
          "description": "AI model to use for reviews"
        },
        "ira.aiApiKey": {
          "type": "string",
          "default": "",
          "description": "API key for the AI provider",
          "scope": "application",
          "order": 1
        },
        "ira.minSeverity": {
          "type": "string",
          "enum": [
            "BLOCKER",
            "CRITICAL",
            "MAJOR",
            "MINOR",
            "INFO"
          ],
          "default": "MAJOR",
          "description": "Minimum severity level to display"
        },
        "ira.githubToken": {
          "type": "string",
          "default": "",
          "description": "GitHub/GHE personal access token (used if VS Code sign-in is unavailable)",
          "scope": "application"
        },
        "ira.githubUrl": {
          "type": "string",
          "default": "",
          "description": "GitHub Enterprise API URL (e.g. https://ghe.company.com/api/v3)"
        },
        "ira.bitbucketToken": {
          "type": "string",
          "default": "",
          "description": "Bitbucket personal access token"
        },
        "ira.bitbucketUrl": {
          "type": "string",
          "default": "",
          "description": "Bitbucket server URL"
        },
        "ira.sonarUrl": {
          "type": "string",
          "default": "",
          "description": "SonarQube server URL"
        },
        "ira.sonarToken": {
          "type": "string",
          "default": "",
          "description": "SonarQube authentication token"
        },
        "ira.sonarProjectKey": {
          "type": "string",
          "default": "",
          "description": "SonarQube project key"
        },
        "ira.jiraType": {
          "type": "string",
          "enum": ["cloud", "server"],
          "default": "",
          "description": "JIRA type: cloud (Atlassian-hosted) or server (self-hosted / Data Center)"
        },
        "ira.jiraUrl": {
          "type": "string",
          "default": "",
          "description": "JIRA instance URL"
        },
        "ira.jiraEmail": {
          "type": "string",
          "default": "",
          "description": "JIRA account email"
        },
        "ira.jiraToken": {
          "type": "string",
          "default": "",
          "description": "JIRA API token"
        },
        "ira.jiraAcField": {
          "type": "string",
          "default": "",
          "description": "JIRA custom field ID for Acceptance Criteria (e.g. customfield_10035). Leave empty to auto-detect."
        },
        "ira.jiraAcSource": {
          "type": "string",
          "enum": [
            "customField",
            "description",
            "both"
          ],
          "default": "both",
          "description": "Where to read acceptance criteria from: custom field, description, or both (tries custom field first, falls back to description)"
        },
        "ira.autoReviewOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically review files on save"
        },
        "ira.slackWebhookUrl": {
          "type": "string",
          "default": "",
          "description": "Slack webhook URL for review notifications",
          "scope": "application"
        },
        "ira.teamsWebhookUrl": {
          "type": "string",
          "default": "",
          "description": "Microsoft Teams webhook URL for review notifications",
          "scope": "application"
        },
        "ira.notifyMinRisk": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"],
          "default": "low",
          "description": "Minimum risk level to trigger notifications (low = notify on every review)"
        },
        "ira.notifyOnAcFail": {
          "type": "boolean",
          "default": false,
          "description": "Send notification when JIRA acceptance criteria fail, regardless of risk level"
        }
      }
    },
    "jsonValidation": [
      {
        "fileMatch": ".ira-rules.json",
        "url": "./schemas/ira-rules.schema.json"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ira-explorer",
          "title": "IRA Review",
          "icon": "resources/ira-icon.svg"
        }
      ]
    },
    "views": {
      "ira-explorer": [
        {
          "id": "ira-issues",
          "name": "Issues"
        },
        {
          "id": "ira-history",
          "name": "History ⭐"
        },
        {
          "type": "webview",
          "id": "ira-dashboard",
          "name": "Trends ⭐"
        }
      ]
    }
  }
}
